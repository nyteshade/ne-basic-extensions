{
  "author": "Brielle Harrison <nyteshade at gmail.com>",
  "browser": "dist/@nejs/basic-extensions.bundle.2.22.12.js",
  "description": "Basic but commonly used extensions",
  "dependencies": {
    "@nejs/enumeration": "^1.0.2",
    "@nejs/extension": "^2.24.0"
  },
  "devDependencies": {
    "@nejs/jsdoc-react-theme": "^2.1.1",
    "esbuild": "^0.25.3",
    "vitest": "^3.1.2"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "browser": "./dist/esm/basic-extensions.mjs",
      "import": "./src/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./classes": {
      "import": "./src/classes/index.js",
      "require": "./dist/cjs/classes/index.cjs"
    },
    "./utils": {
      "import": "./src/utils/index.js",
      "require": "./dist/cjs/utils/index.cjs"
    }
  },
  "keywords": [
    "javascript",
    "browser",
    "localStorage"
  ],
  "license": "MIT",
  "main": "dist/cjs/index.cjs",
  "module": "src/index.js",
  "name": "@nejs/basic-extensions",
  "scripts": {
    "build": "bin/clean && bin/version patch bump && bin/esbuild",
    "distribute": "bin/clean && bin/version minor bump && bin/esbuild && npm publish --access public",
    "browser": "bin/esbuild",
    "docs": "npx jsdoc-react src -o docs",
    "clean": "bin/clean",
    "prepack": "bin/clean && bin/esbuild",
    "repl": "npm run build && node --no-warnings repl.bootstrap.js",
    "test": "vitest"
  },
  "type": "module",
  "version": "2.22.12"
}